HA_MONITOR_MQTT_HOST=10.0.0.1
HA_MONITOR_MQTT_PORT=1883
HA_MONITOR_MQTT_USERNAME=homeassistant
HA_MONITOR_MQTT_PASSWORD=change-me
HA_MONITOR_DISCOVERY_PREFIX=homeassistant
HA_MONITOR_HOME_ASSISTANT_STATUS_TOPIC=homeassistant/status
HA_MONITOR_TOPIC_PREFIX=monitor/system
# HA_MONITOR_NODE_ID=my_host
# HA_MONITOR_DEVICE_NAME=My Host System Monitor
HA_MONITOR_CPU_INTERVAL_SECS=1
HA_MONITOR_GPU_INTERVAL_SECS=1
HA_MONITOR_MEMORY_INTERVAL_SECS=5
HA_MONITOR_DISK_INTERVAL_SECS=30
HA_MONITOR_CPU_CHANGE_THRESHOLD_PCT=1.0
HA_MONITOR_GPU_USAGE_CHANGE_THRESHOLD_PCT=1.0
HA_MONITOR_GPU_MEMORY_CHANGE_THRESHOLD_MIB=8
HA_MONITOR_MEMORY_CHANGE_THRESHOLD_MIB=8
HA_MONITOR_DISK_CHANGE_THRESHOLD_MIB=32
HA_MONITOR_CPU_SMOOTHING_WINDOW=5
HA_MONITOR_CPU_MAX_SILENCE_SECS=30
HA_MONITOR_GPU_MAX_SILENCE_SECS=30
HA_MONITOR_MEMORY_MAX_SILENCE_SECS=120
HA_MONITOR_DISK_MAX_SILENCE_SECS=900
HA_MONITOR_ENABLE_SHUTDOWN_BUTTON=false
HA_MONITOR_SHUTDOWN_PAYLOAD=shutdown
HA_MONITOR_SHUTDOWN_DRY_RUN=false
